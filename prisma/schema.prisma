generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HouseholdStatus {
  active
  archived
}

enum MemberRole {
  owner
  coparent
}

enum MemberStatus {
  pending
  active
  removed
}

enum InviteStatus {
  pending
  accepted
  expired
  revoked
}

// --- Phase 2 Enums ---
enum FamilyCircleRole {
  viewer
  contributor
  carer
}

enum FamilyCircleAccessType {
  ongoing
  custom_date
}

enum FamilyCircleMemberStatus {
  pending
  active
  revoked
  expired
}

enum ParentRole {
  owner
  coparent
}

// --- Phase 3 Enums ---
enum EventChildScope {
  both
  single
}

enum EventCategory {
  activity
  health
  school
  handoff
  other
}

enum EventHealthSubType {
  routine
  specialist
  emergency
}

enum EventRecurrenceType {
  none
  daily
  weekly
  biweekly
  monthly
}

enum EventApprovalStatus {
  none
  pending
  approved
  rejected
  auto_approved
}

enum EventTimelineEntryType {
  created
  approval_requested
  approved
  rejected
  auto_approved
  updated
  counter_proposed
}

enum EventTimelineColor {
  sage
  gold
  terracotta
  muted
}

enum EventApprovalRequestStatus {
  pending
  approved
  rejected
  auto_approved
  cancelled
}

enum EventNotificationType {
  event_created
  approval_requested
  event_approved
  event_rejected
  event_auto_approved
  event_updated
}

// --- Phase 4 Enums ---
enum ExpenseChildScope {
  both
  single
}

enum ExpenseStatus {
  draft
  awaiting
  approved
  rejected
  settled
}

enum ExpensePaidBy {
  owner
  coparent
}

enum ReimbursementStatus {
  none
  awaiting_reimb
  partial
  fully_received
}

enum ExpenseSettlementMethod {
  venmo
  zelle
  bank_transfer
  paypal
  cash
  other
}

enum ExpenseSplitType {
  default
  category
  custom
}

enum ExpenseBackdateCategory {
  recent
  backdated
  significant
}

enum ExpenseApprovalTrigger {
  none
  threshold
  significant_backdate
}

enum ExpenseTimelineEntryType {
  created
  submitted_for_approval
  approved
  rejected
  updated
  approval_requirement_removed
  reimbursement_status_updated
  reimbursement_amount_updated
  settled
  settlement_updated
  series_created
  series_paused
  series_resumed
  series_archived
  detached_from_series
  series_future_updated
}

enum ExpenseSeriesFrequency {
  weekly
  biweekly
  monthly
}

enum ExpenseTimelineColor {
  sage
  gold
  terracotta
  muted
}

// --- Phase 5 Enums ---
enum ConversationType {
  coparent
  group
}

enum ConversationPurposeBadge {
  coordination
  medical
  school
  general
}

enum ConversationMemberKind {
  profile
  family_circle
}

// --- Profiles ---
// No household_id - profiles are cross-household
model Profile {
  id           String   @id @default(uuid()) @db.Uuid
  authUserId   String?  @unique @map("auth_user_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  phone        String?
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  householdMembers  HouseholdMember[]
  createdHouseholds Household[]        @relation("CreatedByProfile")
  sentInvites       CoparentInvite[]   @relation("InviteSender")
  acceptedInvites   CoparentInvite[]   @relation("InviteAcceptor")
  onboardingStates  OnboardingState[]
  userSettings      UserSettings[]
  createdCategories Category[]
  createdChildren          Child[]                    @relation("CreatedChildren")
  createdSchedules         CustodySchedule[]          @relation("CreatedSchedules")
  invitedFamilyCircle      FamilyCircleMember[]       @relation("InvitedFamilyCircleMembers")
  joinedFamilyCircle       FamilyCircleMember[]       @relation("JoinedFamilyCircleMembers")
  familyCircleActivityLogs FamilyCircleActivityLog[]  @relation("FamilyCircleActivityActor")

  // Phase 3: Events
  createdEvents              Event[]                 @relation("EventCreator")
  updatedEvents              Event[]                 @relation("EventUpdater")
  approvedEvents             Event[]                 @relation("EventApprover")
  rejectedEvents             Event[]                 @relation("EventRejecter")
  checkedChecklistItems      EventChecklistItem[]    @relation("ChecklistChecker")
  createdChecklistItems      EventChecklistItem[]    @relation("ChecklistCreator")
  actorTimelineEntries       EventTimelineEntry[]    @relation("TimelineActor")
  requestedApprovalRequests  EventApprovalRequest[]  @relation("ApprovalRequester")
  targetedApprovalRequests   EventApprovalRequest[]  @relation("ApprovalTarget")
  resolvedApprovalRequests   EventApprovalRequest[]  @relation("ApprovalResolver")
  targetedNotifications      EventNotification[]     @relation("NotificationTarget")

  // Phase 4: Expenses
  createdExpenses            Expense[]               @relation("ExpenseCreator")
  approvedExpenses           Expense[]               @relation("ExpenseApprover")
  rejectedExpenses           Expense[]               @relation("ExpenseRejecter")
  settledExpenses            Expense[]               @relation("ExpenseSettler")
  expenseTimelineEntries     ExpenseTimelineEntry[]   @relation("ExpenseTimelineActor")
  createdExpenseSeries       ExpenseSeries[]          @relation("ExpenseSeriesCreator")

  // Phase 5: Conversations
  createdConversations       Conversation[]           @relation("ConversationCreator")
  conversationMemberships    ConversationMember[]     @relation("ConversationMemberProfile")

  @@map("profiles")
}

// --- Households ---
model Household {
  id                 String          @id @default(uuid()) @db.Uuid
  name               String
  createdBy          String          @map("created_by") @db.Uuid
  status             HouseholdStatus @default(active)
  timezone           String?
  handoffTimeDefault String?         @map("handoff_time_default")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  creator          Profile           @relation("CreatedByProfile", fields: [createdBy], references: [id])
  members          HouseholdMember[]
  invites          CoparentInvite[]
  onboardingStates OnboardingState[]
  userSettings     UserSettings[]
  categories       Category[]
  children                Child[]
  childSchoolCares        ChildSchoolCare[]
  childMedicals           ChildMedical[]
  emergencyContacts       EmergencyContact[]
  custodySchedules        CustodySchedule[]
  custodyScheduleDays     CustodyScheduleDay[]
  handoffPreferences      HandoffPreference[]
  familyCircleMembers     FamilyCircleMember[]
  familyCircleMemberChildren FamilyCircleMemberChild[]
  familyCircleActivityLogs   FamilyCircleActivityLog[]

  // Phase 3: Events
  events                   Event[]
  eventChecklistItems      EventChecklistItem[]
  eventTimelineEntries     EventTimelineEntry[]
  eventApprovalRequests    EventApprovalRequest[]
  eventNotifications       EventNotification[]

  // Phase 4: Expenses
  expenses                 Expense[]
  expenseTimelineEntries   ExpenseTimelineEntry[]
  expenseSeries            ExpenseSeries[]

  // Phase 5: Conversations
  conversations            Conversation[]
  conversationMembers      ConversationMember[]

  @@map("households")
}

// --- Household Members ---
model HouseholdMember {
  id          String       @id @default(uuid()) @db.Uuid
  householdId String       @map("household_id") @db.Uuid
  profileId   String       @map("profile_id") @db.Uuid
  role        MemberRole   @default(coparent)
  status      MemberStatus @default(active)
  joinedAt    DateTime     @default(now()) @map("joined_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id])
  profile   Profile   @relation(fields: [profileId], references: [id])

  @@unique([householdId, profileId])
  @@map("household_members")
}

// --- Co-parent Invites ---
model CoparentInvite {
  id          String       @id @default(uuid()) @db.Uuid
  householdId String       @map("household_id") @db.Uuid
  invitedBy   String       @map("invited_by") @db.Uuid
  inviteCode  String       @unique @map("invite_code")
  inviteEmail String?      @map("invite_email")
  status      InviteStatus @default(pending)
  expiresAt   DateTime     @map("expires_at")
  acceptedBy  String?      @map("accepted_by") @db.Uuid
  acceptedAt  DateTime?    @map("accepted_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id])
  sender    Profile   @relation("InviteSender", fields: [invitedBy], references: [id])
  acceptor  Profile?  @relation("InviteAcceptor", fields: [acceptedBy], references: [id])

  @@map("coparent_invites")
}

// --- Onboarding State ---
model OnboardingState {
  id             String   @id @default(uuid()) @db.Uuid
  householdId    String   @map("household_id") @db.Uuid
  profileId      String   @map("profile_id") @db.Uuid
  currentStep    String   @default("profile") @map("current_step")
  completedSteps Json     @default("[]") @map("completed_steps")
  isComplete     Boolean  @default(false) @map("is_complete")
  payload        Json     @default("{}") @map("payload")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id])
  profile   Profile   @relation(fields: [profileId], references: [id])

  @@unique([householdId, profileId])
  @@map("onboarding_state")
}

// --- User Settings ---
model UserSettings {
  id          String   @id @default(uuid()) @db.Uuid
  householdId String   @map("household_id") @db.Uuid
  profileId   String?  @map("profile_id") @db.Uuid
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id])
  profile   Profile?  @relation(fields: [profileId], references: [id])

  @@unique([householdId, profileId])
  @@map("user_settings")
}

// --- Categories ---
model Category {
  id         String    @id @default(uuid()) @db.Uuid
  householdId String   @map("household_id") @db.Uuid
  label      String
  slug       String
  emoji      String
  color      String
  position   Int       @default(0)
  isDefault  Boolean   @default(true) @map("is_default")
  archivedAt DateTime? @map("archived_at")
  createdBy  String    @map("created_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id])
  creator   Profile   @relation(fields: [createdBy], references: [id])
  expenses       Expense[]
  expenseSeries  ExpenseSeries[]

  @@unique([householdId, slug])
  @@map("categories")
}

// --- Phase 2: Children ---
model Child {
  id                 String   @id @default(uuid()) @db.Uuid
  householdId        String   @map("household_id") @db.Uuid
  firstName          String   @map("first_name")
  lastName           String?  @map("last_name")
  dob                DateTime @db.Date
  emoji              String
  color              String
  photoUrl           String?  @map("photo_url")
  allergyNote        String?  @map("allergy_note")
  createdByProfileId String   @map("created_by_profile_id") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  household          Household                @relation(fields: [householdId], references: [id])
  createdByProfile   Profile                  @relation("CreatedChildren", fields: [createdByProfileId], references: [id])
  schoolCare         ChildSchoolCare?
  medical            ChildMedical?
  emergencyContacts  EmergencyContact[]
  familyCircleLinks  FamilyCircleMemberChild[]
  events             Event[]                    @relation("EventPrimaryChild")
  expenses           Expense[]                  @relation("ExpensePrimaryChild")
  expenseSeries      ExpenseSeries[]            @relation("ExpenseSeriesPrimaryChild")

  @@map("children")
}

// --- Phase 2: Child School/Care ---
model ChildSchoolCare {
  id          String   @id @default(uuid()) @db.Uuid
  householdId String   @map("household_id") @db.Uuid
  childId     String   @unique @map("child_id") @db.Uuid
  schoolName  String?  @map("school_name")
  teacherName String?  @map("teacher_name")
  hours       String?
  address     String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id])
  child     Child     @relation(fields: [childId], references: [id])

  @@map("child_school_care")
}

// --- Phase 2: Child Medical ---
model ChildMedical {
  id                String   @id @default(uuid()) @db.Uuid
  householdId       String   @map("household_id") @db.Uuid
  childId           String   @unique @map("child_id") @db.Uuid
  pediatrician      String?
  pediatricianPhone String?  @map("pediatrician_phone")
  hospital          String?
  bloodType         String?  @map("blood_type")
  medications       Json     @default("[]")
  allergies         Json     @default("[]")
  insurance         Json?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id])
  child     Child     @relation(fields: [childId], references: [id])

  @@map("child_medical")
}

// --- Phase 2: Emergency Contacts ---
model EmergencyContact {
  id          String   @id @default(uuid()) @db.Uuid
  householdId String   @map("household_id") @db.Uuid
  childId     String   @map("child_id") @db.Uuid
  name        String
  relationship String
  phone       String
  initial     String?
  color       String?
  isPrimary   Boolean  @default(false) @map("is_primary")
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id])
  child     Child     @relation(fields: [childId], references: [id])

  @@map("emergency_contacts")
}

// --- Phase 2: Custody Schedules ---
model CustodySchedule {
  id                  String    @id @default(uuid()) @db.Uuid
  householdId         String    @map("household_id") @db.Uuid
  name                String
  isActive            Boolean   @default(true) @map("is_active")
  patternType         String?   @map("pattern_type")
  firstDayOfWeek      Int       @default(1) @map("first_day_of_week") @db.SmallInt
  handoffTimeDefault  String?   @map("handoff_time_default")
  effectiveFrom       DateTime? @map("effective_from") @db.Date
  effectiveTo         DateTime? @map("effective_to") @db.Date
  createdByProfileId  String    @map("created_by_profile_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  household          Household            @relation(fields: [householdId], references: [id])
  createdByProfile   Profile              @relation("CreatedSchedules", fields: [createdByProfileId], references: [id])
  days               CustodyScheduleDay[]
  handoffPreference  HandoffPreference?

  @@map("custody_schedules")
}

// --- Phase 2: Custody Schedule Days ---
model CustodyScheduleDay {
  id                 String     @id @default(uuid()) @db.Uuid
  householdId        String     @map("household_id") @db.Uuid
  custodyScheduleId  String     @map("custody_schedule_id") @db.Uuid
  weekIndex          Int        @map("week_index")
  dayIndex           Int        @map("day_index")
  assignedParentRole ParentRole @map("assigned_parent_role")
  isHandoffDay       Boolean    @default(false) @map("is_handoff_day")
  handoffTime        String?    @map("handoff_time")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  household       Household       @relation(fields: [householdId], references: [id])
  custodySchedule CustodySchedule @relation(fields: [custodyScheduleId], references: [id], onDelete: Cascade)

  @@unique([custodyScheduleId, weekIndex, dayIndex])
  @@map("custody_schedule_days")
}

// --- Phase 2: Handoff Preferences ---
model HandoffPreference {
  id                      String   @id @default(uuid()) @db.Uuid
  householdId             String   @map("household_id") @db.Uuid
  custodyScheduleId       String?  @unique @map("custody_schedule_id") @db.Uuid
  remindersEnabled        Boolean  @default(true) @map("reminders_enabled")
  reminderDayBefore       Boolean  @default(true) @map("reminder_day_before")
  reminderTwoHoursBefore  Boolean  @default(true) @map("reminder_two_hours_before")
  defaultLocation         String?  @map("default_location")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  household       Household        @relation(fields: [householdId], references: [id])
  custodySchedule CustodySchedule? @relation(fields: [custodyScheduleId], references: [id])

  @@map("handoff_preferences")
}

// --- Phase 2: Family Circle Members ---
model FamilyCircleMember {
  id                 String                    @id @default(uuid()) @db.Uuid
  householdId        String                    @map("household_id") @db.Uuid
  name               String
  email              String?
  phone              String?
  relationship       String
  role               FamilyCircleRole
  accessType         FamilyCircleAccessType    @map("access_type")
  accessStartsAt     DateTime?                 @map("access_starts_at")
  accessEndsAt       DateTime?                 @map("access_ends_at")
  status             FamilyCircleMemberStatus  @default(pending)
  inviteCode         String?                   @unique @map("invite_code")
  invitedByProfileId String?                   @map("invited_by_profile_id") @db.Uuid
  joinedProfileId    String?                   @map("joined_profile_id") @db.Uuid
  avatarUrl          String?                   @map("avatar_url")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")

  household          Household                  @relation(fields: [householdId], references: [id])
  invitedByProfile   Profile?                   @relation("InvitedFamilyCircleMembers", fields: [invitedByProfileId], references: [id])
  joinedProfile      Profile?                   @relation("JoinedFamilyCircleMembers", fields: [joinedProfileId], references: [id])
  childAssignments   FamilyCircleMemberChild[]
  activityLogs       FamilyCircleActivityLog[]
  conversationMemberships ConversationMember[]

  @@map("family_circle_members")
}

// --- Phase 2: Family Circle Member <-> Children ---
model FamilyCircleMemberChild {
  id                   String   @id @default(uuid()) @db.Uuid
  householdId          String   @map("household_id") @db.Uuid
  familyCircleMemberId String   @map("family_circle_member_id") @db.Uuid
  childId              String   @map("child_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")

  household          Household          @relation(fields: [householdId], references: [id])
  familyCircleMember FamilyCircleMember @relation(fields: [familyCircleMemberId], references: [id], onDelete: Cascade)
  child              Child              @relation(fields: [childId], references: [id])

  @@unique([familyCircleMemberId, childId])
  @@map("family_circle_member_children")
}

// --- Phase 2: Family Circle Activity Log ---
model FamilyCircleActivityLog {
  id                   String   @id @default(uuid()) @db.Uuid
  householdId          String   @map("household_id") @db.Uuid
  familyCircleMemberId String   @map("family_circle_member_id") @db.Uuid
  childId              String?  @map("child_id") @db.Uuid
  actorProfileId       String?  @map("actor_profile_id") @db.Uuid
  action               String
  metadata             Json     @default("{}")
  createdAt            DateTime @default(now()) @map("created_at")

  household          Household          @relation(fields: [householdId], references: [id])
  familyCircleMember FamilyCircleMember @relation(fields: [familyCircleMemberId], references: [id])
  actorProfile       Profile?           @relation("FamilyCircleActivityActor", fields: [actorProfileId], references: [id])

  @@map("family_circle_activity_log")
}

// --- Phase 3: Events ---
model Event {
  id                      String               @id @default(uuid()) @db.Uuid
  householdId             String               @map("household_id") @db.Uuid
  createdByProfileId      String               @map("created_by_profile_id") @db.Uuid
  updatedByProfileId      String?              @map("updated_by_profile_id") @db.Uuid
  title                   String
  emoji                   String
  childScope              EventChildScope      @map("child_scope")
  primaryChildId          String?              @map("primary_child_id") @db.Uuid
  category                EventCategory
  healthSubType           EventHealthSubType?  @map("health_sub_type")
  startAt                 DateTime             @map("start_at")
  endAt                   DateTime             @map("end_at")
  allDay                  Boolean              @default(false) @map("all_day")
  location                String?
  notes                   String?
  notify                  Boolean              @default(true)
  recurrenceType          EventRecurrenceType  @default(none) @map("recurrence_type")
  recurrenceUntil         DateTime?            @map("recurrence_until")
  recurrenceParentEventId String?              @map("recurrence_parent_event_id") @db.Uuid
  approvalStatus          EventApprovalStatus  @default(none) @map("approval_status")
  approvalDeadlineAt      DateTime?            @map("approval_deadline_at")
  approvedAt              DateTime?            @map("approved_at")
  approvedByProfileId     String?              @map("approved_by_profile_id") @db.Uuid
  autoApprovedAt          DateTime?            @map("auto_approved_at")
  rejectedAt              DateTime?            @map("rejected_at")
  rejectedByProfileId     String?              @map("rejected_by_profile_id") @db.Uuid
  rejectionReason         String?              @map("rejection_reason")
  rejectionCounterType    String?              @map("rejection_counter_type")
  rejectionCounterValue   String?              @map("rejection_counter_value")
  isDeleted               Boolean              @default(false) @map("is_deleted")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

  household          Household              @relation(fields: [householdId], references: [id])
  createdByProfile   Profile                @relation("EventCreator", fields: [createdByProfileId], references: [id])
  updatedByProfile   Profile?               @relation("EventUpdater", fields: [updatedByProfileId], references: [id])
  approvedByProfile  Profile?               @relation("EventApprover", fields: [approvedByProfileId], references: [id])
  rejectedByProfile  Profile?               @relation("EventRejecter", fields: [rejectedByProfileId], references: [id])
  primaryChild       Child?                 @relation("EventPrimaryChild", fields: [primaryChildId], references: [id])
  recurrenceParent   Event?                 @relation("RecurrenceParent", fields: [recurrenceParentEventId], references: [id])
  recurrenceChildren Event[]                @relation("RecurrenceParent")
  checklistItems     EventChecklistItem[]
  timelineEntries    EventTimelineEntry[]
  approvalRequests   EventApprovalRequest[]
  notifications      EventNotification[]

  @@index([householdId, startAt])
  @@index([householdId, approvalStatus])
  @@index([recurrenceParentEventId])
  @@map("events")
}

// --- Phase 3: Event Checklist Items ---
model EventChecklistItem {
  id                 String    @id @default(uuid()) @db.Uuid
  householdId        String    @map("household_id") @db.Uuid
  eventId            String    @map("event_id") @db.Uuid
  text               String
  checked            Boolean   @default(false)
  checkedAt          DateTime? @map("checked_at")
  checkedByProfileId String?   @map("checked_by_profile_id") @db.Uuid
  position           Int       @default(0)
  createdByProfileId String?   @map("created_by_profile_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  household        Household @relation(fields: [householdId], references: [id])
  event            Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  checkedByProfile Profile?  @relation("ChecklistChecker", fields: [checkedByProfileId], references: [id])
  createdByProfile Profile?  @relation("ChecklistCreator", fields: [createdByProfileId], references: [id])

  @@index([eventId])
  @@map("event_checklist_items")
}

// --- Phase 3: Event Timeline Entries ---
model EventTimelineEntry {
  id             String                 @id @default(uuid()) @db.Uuid
  householdId    String                 @map("household_id") @db.Uuid
  eventId        String                 @map("event_id") @db.Uuid
  actorProfileId String?                @map("actor_profile_id") @db.Uuid
  entryType      EventTimelineEntryType @map("entry_type")
  label          String
  detail         String?
  color          EventTimelineColor
  createdAt      DateTime               @default(now()) @map("created_at")

  household    Household @relation(fields: [householdId], references: [id])
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  actorProfile Profile?  @relation("TimelineActor", fields: [actorProfileId], references: [id])

  @@index([eventId])
  @@map("event_timeline_entries")
}

// --- Phase 3: Event Approval Requests ---
model EventApprovalRequest {
  id                   String                     @id @default(uuid()) @db.Uuid
  householdId          String                     @map("household_id") @db.Uuid
  eventId              String                     @map("event_id") @db.Uuid
  requestedByProfileId String                     @map("requested_by_profile_id") @db.Uuid
  requestedToProfileId String?                    @map("requested_to_profile_id") @db.Uuid
  status               EventApprovalRequestStatus @default(pending)
  deadlineAt           DateTime                   @map("deadline_at")
  resolvedAt           DateTime?                  @map("resolved_at")
  resolvedByProfileId  String?                    @map("resolved_by_profile_id") @db.Uuid
  createdAt            DateTime                   @default(now()) @map("created_at")
  updatedAt            DateTime                   @updatedAt @map("updated_at")

  household          Household @relation(fields: [householdId], references: [id])
  event              Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  requestedByProfile Profile   @relation("ApprovalRequester", fields: [requestedByProfileId], references: [id])
  requestedToProfile Profile?  @relation("ApprovalTarget", fields: [requestedToProfileId], references: [id])
  resolvedByProfile  Profile?  @relation("ApprovalResolver", fields: [resolvedByProfileId], references: [id])

  @@index([eventId, status])
  @@index([requestedToProfileId, status])
  @@map("event_approval_requests")
}

// --- Phase 3: Event Notifications ---
model EventNotification {
  id              String                @id @default(uuid()) @db.Uuid
  householdId     String                @map("household_id") @db.Uuid
  eventId         String                @map("event_id") @db.Uuid
  type            EventNotificationType
  targetProfileId String?               @map("target_profile_id") @db.Uuid
  payload         Json                  @default("{}")
  createdAt       DateTime              @default(now()) @map("created_at")
  processedAt     DateTime?             @map("processed_at")

  household     Household @relation(fields: [householdId], references: [id])
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  targetProfile Profile?  @relation("NotificationTarget", fields: [targetProfileId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([processedAt])
  @@map("event_notifications")
}

// --- Phase 4: Expenses ---
model Expense {
  id                 String             @id @default(uuid()) @db.Uuid
  householdId        String             @map("household_id") @db.Uuid
  createdByProfileId String             @map("created_by_profile_id") @db.Uuid
  description        String
  amount             Decimal            @db.Decimal(10, 2)
  paidBy             ExpensePaidBy      @map("paid_by")
  date               DateTime           @db.Date
  childScope         ExpenseChildScope  @map("child_scope")
  primaryChildId     String?            @map("primary_child_id") @db.Uuid
  categoryId         String             @map("category_id") @db.Uuid
  status             ExpenseStatus      @default(draft)
  splitPct           Int                @default(50) @map("split_pct") @db.SmallInt
  splitType          ExpenseSplitType   @default(default) @map("split_type")
  splitReason        String?            @map("split_reason")
  backdateCategory   ExpenseBackdateCategory @default(recent) @map("backdate_category")
  backdateReason     String?            @map("backdate_reason")
  approvalRequired   Boolean            @default(false) @map("approval_required")
  approvalTrigger    ExpenseApprovalTrigger @default(none) @map("approval_trigger")
  approvedAt          DateTime?          @map("approved_at")
  approvedByProfileId String?            @map("approved_by_profile_id") @db.Uuid
  rejectedAt          DateTime?          @map("rejected_at")
  rejectedByProfileId String?            @map("rejected_by_profile_id") @db.Uuid
  rejectionReason     String?            @map("rejection_reason")
  reimbursable       Boolean            @default(false)
  reimbursedAmt      Decimal            @default(0) @map("reimbursed_amt") @db.Decimal(10, 2)
  reimbursementStatus ReimbursementStatus @default(none) @map("reimbursement_status")
  reimbursementSource String?            @map("reimbursement_source")
  reimbursedAmtExpected Decimal?         @map("reimbursed_amt_expected") @db.Decimal(10, 2)
  settlementMethod   ExpenseSettlementMethod? @map("settlement_method")
  settlementDate     DateTime?          @map("settlement_date") @db.Date
  settlementNote     String?            @map("settlement_note")
  settledByProfileId String?            @map("settled_by_profile_id") @db.Uuid
  settledAt          DateTime?          @map("settled_at")
  notes              String?
  seriesId              String?  @map("series_id") @db.Uuid
  seriesInstanceDate    DateTime? @map("series_instance_date") @db.Date
  isDetachedFromSeries  Boolean  @default(false) @map("is_detached_from_series")
  deletedAt          DateTime?          @map("deleted_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  household        Household @relation(fields: [householdId], references: [id])
  createdByProfile  Profile   @relation("ExpenseCreator", fields: [createdByProfileId], references: [id])
  approvedByProfile Profile?  @relation("ExpenseApprover", fields: [approvedByProfileId], references: [id])
  rejectedByProfile Profile?  @relation("ExpenseRejecter", fields: [rejectedByProfileId], references: [id])
  settledByProfile  Profile?  @relation("ExpenseSettler", fields: [settledByProfileId], references: [id])
  primaryChild      Child?    @relation("ExpensePrimaryChild", fields: [primaryChildId], references: [id])
  category          Category  @relation(fields: [categoryId], references: [id])
  series            ExpenseSeries? @relation(fields: [seriesId], references: [id])
  timelineEntries   ExpenseTimelineEntry[]

  @@index([householdId, date])
  @@index([householdId, status])
  @@index([householdId, categoryId])
  @@index([seriesId, seriesInstanceDate])
  @@map("expenses")
}

// --- Phase 4C2: Expense Timeline Entries ---
model ExpenseTimelineEntry {
  id             String                    @id @default(uuid()) @db.Uuid
  householdId    String                    @map("household_id") @db.Uuid
  expenseId      String                    @map("expense_id") @db.Uuid
  actorProfileId String?                   @map("actor_profile_id") @db.Uuid
  entryType      ExpenseTimelineEntryType  @map("entry_type")
  label          String
  detail         String?
  color          ExpenseTimelineColor
  createdAt      DateTime                  @default(now()) @map("created_at")

  household    Household @relation(fields: [householdId], references: [id])
  expense      Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  actorProfile Profile?  @relation("ExpenseTimelineActor", fields: [actorProfileId], references: [id])

  @@index([expenseId])
  @@map("expense_timeline_entries")
}

// --- Phase 4D2: Recurring Expense Series ---
model ExpenseSeries {
  id                 String                  @id @default(uuid()) @db.Uuid
  householdId        String                  @map("household_id") @db.Uuid
  createdByProfileId String                  @map("created_by_profile_id") @db.Uuid
  description        String
  amount             Decimal                 @db.Decimal(10, 2)
  paidBy             ExpensePaidBy           @map("paid_by")
  childScope         ExpenseChildScope       @map("child_scope")
  primaryChildId     String?                 @map("primary_child_id") @db.Uuid
  categoryId         String                  @map("category_id") @db.Uuid
  splitPct           Int                     @default(50) @map("split_pct") @db.SmallInt
  splitType          ExpenseSplitType        @default(default) @map("split_type")
  splitReason        String?                 @map("split_reason")
  notes              String?
  reimbursable       Boolean                 @default(false)

  frequency          ExpenseSeriesFrequency
  intervalCount      Int                     @default(1) @map("interval_count")
  dayOfMonth         Int?                    @map("day_of_month") @db.SmallInt
  startDate          DateTime                @map("start_date") @db.Date
  endDate            DateTime?               @map("end_date") @db.Date
  nextGenerationDate DateTime?               @map("next_generation_date") @db.Date
  paused             Boolean                 @default(false)
  archivedAt         DateTime?               @map("archived_at")

  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  household          Household               @relation(fields: [householdId], references: [id])
  createdByProfile   Profile                 @relation("ExpenseSeriesCreator", fields: [createdByProfileId], references: [id])
  primaryChild       Child?                  @relation("ExpenseSeriesPrimaryChild", fields: [primaryChildId], references: [id])
  category           Category                @relation(fields: [categoryId], references: [id])
  expenses           Expense[]

  @@index([householdId])
  @@index([householdId, paused])
  @@map("expense_series")
}

// --- Phase 5A: Conversations ---
model Conversation {
  id                 String                    @id @default(uuid()) @db.Uuid
  householdId        String                    @map("household_id") @db.Uuid
  type               ConversationType
  name               String?
  purposeBadge       ConversationPurposeBadge? @map("purpose_badge")
  pinned             Boolean                   @default(false)
  createdByProfileId String?                   @map("created_by_profile_id") @db.Uuid
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")
  deletedAt          DateTime?                 @map("deleted_at")

  household        Household            @relation(fields: [householdId], references: [id])
  createdByProfile Profile?             @relation("ConversationCreator", fields: [createdByProfileId], references: [id])
  members          ConversationMember[]

  @@map("conversations")
}

// --- Phase 5A: Conversation Members ---
model ConversationMember {
  id                   String                  @id @default(uuid()) @db.Uuid
  householdId          String                  @map("household_id") @db.Uuid
  conversationId       String                  @map("conversation_id") @db.Uuid
  memberKind           ConversationMemberKind  @map("member_kind")
  profileId            String?                 @map("profile_id") @db.Uuid
  familyCircleMemberId String?                 @map("family_circle_member_id") @db.Uuid
  role                 String?
  joinedAt             DateTime                @default(now()) @map("joined_at")
  leftAt               DateTime?               @map("left_at")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  household          Household           @relation(fields: [householdId], references: [id])
  conversation       Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  profile            Profile?            @relation("ConversationMemberProfile", fields: [profileId], references: [id])
  familyCircleMember FamilyCircleMember? @relation(fields: [familyCircleMemberId], references: [id])

  @@map("conversation_members")
}
